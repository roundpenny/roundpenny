  "panels": [
    {
      "title": "Auth Service",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": true,
      "panels": [
        {
          "title": "HTTP Request Rate",
          "type": "graph",
          "datasource": "Prometheus",
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
          "targets": [
            {
              "expr": "rate(http_requests_total{service=\"auth\"}[5m])",
              "legendFormat": "{{method}} {{path}}"
            }
          ]
        },
        {
          "title": "Error Rate",
          "type": "graph",
          "datasource": "Prometheus",
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
          "targets": [
            {
              "expr": "rate(http_requests_total{service=\"auth\",status=~\"5..\"}[5m])",
              "legendFormat": "{{method}} {{path}}"
            }
          ]
        },
        {
          "title": "Request Duration (p99)",
          "type": "graph",
          "datasource": "Prometheus",
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
          "targets": [
            {
              "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{service=\"auth\"}[5m]))",
              "legendFormat": "{{method}} {{path}}"
            }
          ]
        }
      ]
    },
