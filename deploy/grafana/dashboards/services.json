{
  "title": "Roundup Platform Services",
  "uid": "roundup-platform-services",
  "version": 2,
  "schemaVersion": 38,
  "editable": true,
  "panels": [
    {
      "title": "Global Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": [
        {
          "title": "Total Request Rate (All Services)",
          "type": "graph",
          "datasource": "Prometheus",
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
          "targets": [
            {
              "expr": "rate({__name__=~\".*_http_requests_total\"}[5m])",
              "legendFormat": "{{__name__}}"
            }
          ]
        },
        {
          "title": "Total Error Rate (All Services)",
          "type": "graph",
          "datasource": "Prometheus",
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
          "targets": [
            {
              "expr": "rate({__name__=~\".*_http_requests_total\",status=~\"5..\"}[5m])",
              "legendFormat": "{{__name__}}"
            }
          ]
        },
        {
          "title": "DB Operations (All Services)",
          "type": "graph",
          "datasource": "Prometheus",
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
          "targets": [
            {
              "expr": "rate({__name__=~\".*_db_operations_total\"}[5m])",
              "legendFormat": "{{__name__}} - {{operation}}"
            }
          ]
        },
        {
          "title": "Circuit Breaker State",
          "type": "graph",
          "datasource": "Prometheus",
          "gridPos": { "h": 6, "w": 24, "x": 0, "y": 2 },
          "targets": [
            {
              "expr": "{__name__=~\".*_circuit_breaker_state\",state=\"open\"} == 1",
              "legendFormat": "{{__name__}} - {{name}}"
            }
          ]
        }
      ]
    },
