# =============================================================================
# RoundPenny Platform - Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- SendGrid (Email) ---
# Used by: auth-service, notification-service
# Get your API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
EMAIL_FROM=noreply@roundpenny.com

# --- Onfido (KYC) ---
# Used by: auth-service
# Get your API token at: https://dashboard.onfido.com/api/documentation
ONFIDO_API_TOKEN=

# --- Stripe (Payments) ---
# Used by: payment-gateway
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Redis ---
# Used by: all services (cache, rate limiting, token blacklist)
# Default for local Docker Compose:
REDIS_ADDR=localhost:6379

# --- JWT ---
# Used by: all services (token signing/validation)
# Generate with: openssl rand -base64 48
JWT_SECRET=roundup-dev-jwt-secret-min-32-chars!!

# --- Database ---
# Used by: all services with data storage
# Default for local Docker Compose:
DATABASE_URL=postgres://roundup:roundup@localhost:5432/roundup?sslmode=disable
